# ============================================================
# TELEGRAM
# ============================================================
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321   # через запятую, без пробелов

# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=botdb
POSTGRES_USER=botuser
POSTGRES_PASSWORD=change_me_strong_password

# ============================================================
# REDIS
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_me_redis_password

# ============================================================
# CELERY
# ============================================================
CELERY_BROKER_URL=redis://:change_me_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@redis:6379/2

# ============================================================
# AI PROVIDERS (основной + резервный)
# ============================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=10          # секунды
OPENAI_MONTHLY_BUDGET_USD=50

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Активный провайдер: openai | anthropic
AI_PROVIDER=openai

# ============================================================
# ПЛАТЁЖНЫЕ СИСТЕМЫ
# ============================================================
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
TELEGRAM_PAYMENTS_TOKEN=

# ============================================================
# EMAIL / РАССЫЛКИ
# ============================================================
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# ХРАНИЛИЩЕ ФАЙЛОВ (S3-совместимое)
# ============================================================
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BUCKET_NAME=your-bucket
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central1

# ============================================================
# ПРИЛОЖЕНИЕ
# ============================================================
APP_ENV=development            # development | staging | production
DEBUG=true
LOG_LEVEL=DEBUG                # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change_me_32_chars_random_string

# Интернационализация
DEFAULT_LOCALE=ru
SUPPORTED_LOCALES=ru,en

# Вебхук (для production)
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

# ============================================================
# SENTRY (мониторинг ошибок)
# ============================================================
SENTRY_DSN=

# ============================================================
# ПОЛИТИКИ БЕЗОПАСНОСТИ
# ============================================================
RATE_LIMIT_MESSAGES=30         # сообщений в минуту на пользователя
RATE_LIMIT_WINDOW=60           # окно в секундах
TRIAL_DAYS=3
